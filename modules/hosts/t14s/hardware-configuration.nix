  fileSystems."/home" = {
    device = "/dev/mapper/luks-8be7d7a8-ad1d-443e-8030-429a1e291ee5";
    fsType = "btrfs";
    options = [
      "compress=zstd"
      "subvol=home"
    ];
  };

  fileSystems."/nix" = {
    device = "/dev/mapper/luks-8be7d7a8-ad1d-443e-8030-429a1e291ee5";
    fsType = "btrfs";
    options = [
      "compress=zstd"
      "subvol=nix"
    ];
  };

  fileSystems."/boot" = {
    device = "/dev/disk/by-uuid/4CBD-945C";
