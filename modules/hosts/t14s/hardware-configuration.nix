  fileSystems."/" = {
    device = "/dev/mapper/luks-8be7d7a8-ad1d-443e-8030-429a1e291ee5";
    fsType = "btrfs";
    options = [ "compress=zstd" ];
  };

  boot.initrd.luks.devices."luks-8be7d7a8-ad1d-443e-8030-429a1e291ee5".device =
